APP_ENV=production
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'
SECURITY_HSTS=max-age=31536000; includeSubDomains
REQUIRE_CSRF_FOR_COOKIE_AUTH=true
CSRF_COOKIE_NAME=mn_csrf_token
MAX_JSON_BODY_BYTES=1048576
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/meetingnotes
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=
ADMIN_API_TOKEN=
GUEST_SESSION_IDLE_TTL_HOURS=168
GUEST_SESSION_MAX_AGE_HOURS=720
GUEST_SESSION_COOKIE_ENABLED=true
GUEST_SESSION_COOKIE_NAME=mn_guest_token
GUEST_SESSION_COOKIE_SECURE=true
GUEST_SESSION_COOKIE_SAMESITE=lax
REAPER_TRIGGER_TOKEN=
STORAGE_BACKEND=s3
S3_BUCKET=meeting-notes-prod
S3_PREFIX=meeting-notes
MAX_UPLOAD_BYTES=26214400
MAX_FILES_PER_UPLOAD_REQUEST=5
MAX_EXTRACTED_TEXT_CHARS=2000000
MAX_CHUNKS_PER_DOCUMENT=600
EXTRACTION_TIMEOUT_SECONDS=120
OCR_TIMEOUT_SECONDS=30
PDF_MAX_PAGES=80
ENABLE_OCR=true
CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_ORIGIN_REGEX=
TRUSTED_PROXY_CIDRS=127.0.0.1/32
RATE_LIMIT_SESSION_CREATE_PER_MINUTE_IP=2
RATE_LIMIT_UPLOAD_PER_MINUTE_IP=8
RATE_LIMIT_UPLOAD_PER_MINUTE_SESSION=15
RATE_LIMIT_REINDEX_PER_MINUTE_IP=8
RATE_LIMIT_REINDEX_PER_MINUTE_SESSION=15
RATE_LIMIT_CHAT_PER_MINUTE_IP=30
RATE_LIMIT_CHAT_PER_MINUTE_SESSION=50
RATE_LIMIT_VERIFY_PER_MINUTE_IP=6
RATE_LIMIT_VERIFY_PER_MINUTE_SESSION=10
QUOTA_UPLOADS_PER_DAY=80
QUOTA_UPLOAD_MB_PER_DAY=200
QUOTA_CHATS_PER_DAY=400
QUOTA_VERIFIES_PER_DAY=80
MAX_ACTIVE_INDEX_JOBS_PER_SESSION=10
REINDEX_COOLDOWN_SECONDS=300
