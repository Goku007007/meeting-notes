APP_ENV=development
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'
SECURITY_HSTS=
REQUIRE_CSRF_FOR_COOKIE_AUTH=true
CSRF_COOKIE_NAME=mn_csrf_token
MAX_JSON_BODY_BYTES=1048576
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meetingnotes
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
ADMIN_API_TOKEN=
GUEST_SESSION_IDLE_TTL_HOURS=168
GUEST_SESSION_MAX_AGE_HOURS=720
GUEST_SESSION_COOKIE_ENABLED=false
GUEST_SESSION_COOKIE_NAME=mn_guest_token
GUEST_SESSION_COOKIE_SECURE=false
GUEST_SESSION_COOKIE_SAMESITE=lax
UPLOADS_DIR=../../uploads
STORAGE_BACKEND=local
# STORAGE_BACKEND=s3 vars
S3_BUCKET=
S3_PREFIX=meeting-notes
MAX_UPLOAD_BYTES=26214400
MAX_FILES_PER_UPLOAD_REQUEST=10
MAX_EXTRACTED_TEXT_CHARS=2000000
MAX_CHUNKS_PER_DOCUMENT=600
EXTRACTION_TIMEOUT_SECONDS=120
OCR_TIMEOUT_SECONDS=30
PDF_MAX_PAGES=100
ENABLE_OCR=false
INDEX_JOB_TIMEOUT_SECONDS=900
INDEX_JOB_RETRY_MAX=3
INDEX_JOB_RETRY_INTERVALS=30,120,300
STALE_PROCESSING_MINUTES=30
REAPER_TRIGGER_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
TRUSTED_PROXY_CIDRS=
RATE_LIMIT_SESSION_CREATE_PER_MINUTE_IP=10
RATE_LIMIT_UPLOAD_PER_MINUTE_IP=20
RATE_LIMIT_UPLOAD_PER_MINUTE_SESSION=30
RATE_LIMIT_REINDEX_PER_MINUTE_IP=20
RATE_LIMIT_REINDEX_PER_MINUTE_SESSION=30
RATE_LIMIT_CHAT_PER_MINUTE_IP=60
RATE_LIMIT_CHAT_PER_MINUTE_SESSION=90
RATE_LIMIT_VERIFY_PER_MINUTE_IP=15
RATE_LIMIT_VERIFY_PER_MINUTE_SESSION=20
QUOTA_UPLOADS_PER_DAY=200
QUOTA_UPLOAD_MB_PER_DAY=500
QUOTA_CHATS_PER_DAY=1000
QUOTA_VERIFIES_PER_DAY=200
MAX_ACTIVE_INDEX_JOBS_PER_SESSION=25
REINDEX_COOLDOWN_SECONDS=120
